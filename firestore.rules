rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Primitives ---
    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---
    function isValidReadingHistory(data) {
      return data.keys().hasAll(['storyName', 'chapterName', 'url', 'sourceHost', 'userId', 'createdAt', 'updatedAt'])
          && data.keys().size() == 7
          && data.userId == request.auth.uid
          && data.storyName is string && data.storyName.size() <= 512
          && data.chapterName is string && data.chapterName.size() <= 512
          && data.url is string && data.url.size() <= 2048
          && data.sourceHost is string && data.sourceHost.size() <= 256;
    }

    // --- Collection Rules ---
    match /reading_history/{historyId} {
      // Allow create if auth matches, ID is prefixed with UID, and meets schema/timestamp
      allow create: if isSignedIn() 
                    && historyId.matches('^' + request.auth.uid + '_[a-zA-Z0-9_]+$')
                    && isValidReadingHistory(incoming())
                    && incoming().createdAt == request.time
                    && incoming().updatedAt == request.time;
      
      // Allow update if auth matches, ID is prefixed with UID, has correct previous user state, and updates time
      allow update: if isSignedIn()
                    && historyId.matches('^' + request.auth.uid + '_[a-zA-Z0-9_]+$')
                    && isValidReadingHistory(incoming())
                    && existing().userId == request.auth.uid
                    && incoming().createdAt == existing().createdAt
                    && incoming().updatedAt == request.time;
      
      // Cho phép get nếu đã đăng nhập và document chưa tồn tại hoặc thuộc về chính user
      allow get: if isSignedIn() 
                 && (resource == null || resource.data.userId == request.auth.uid);

      // Cho phép list nếu đã đăng nhập và lọc theo userId của chính mình
      allow list: if isSignedIn() 
                  && resource.data.userId == request.auth.uid;

      // Cho phép delete nếu đã đăng nhập và document thuộc về chính user hoặc chưa tồn tại
      allow delete: if isSignedIn() 
                    && (resource == null || resource.data.userId == request.auth.uid);
    }
  }
}